{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2022",
        "outDir": "out",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "types": ["node", "mocha"],
        "forceConsistentCasingInFileNames": true
        /* Additional Checks */
        // "noImplicitReturns": true, 
        // "noFallthroughCasesInSwitch": true, 
        // "noUnusedParameters": true,  
    }
}